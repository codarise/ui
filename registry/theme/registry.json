          "ring": "oklch(0.36 0 0)",
          "chart-1": "oklch(0.6701 0.1066 208.6333)",
          "chart-2": "oklch(0.6839 0.1126 162.0492)",
          "chart-3": "oklch(0.6231 0.188 259.8145)",
          "chart-4": "oklch(0.7686 0.1647 70.0804)",
          "chart-5": "oklch(0.6559 0.2118 354.3084)",
          "sidebar": "oklch(0.1448 0 0)",
          "sidebar-foreground": "oklch(0.9851 0 0)",
          "sidebar-primary": "oklch(0.6701 0.1066 208.6333)",
          "sidebar-primary-foreground": "oklch(0.9851 0 0)",
          "sidebar-accent": "oklch(0.36 0 0)",
          "sidebar-accent-foreground": "oklch(0.9851 0 0)",
          "sidebar-border": "oklch(0.36 0 0)",
          "sidebar-ring": "oklch(0.5897 0 0)"
        },
        "theme": {
          "color-background": "var(--background)",
          "color-foreground": "var(--foreground)",
          "color-card": "var(--card)",
          "color-card-foreground": "var(--card-foreground)",
          "color-popover": "var(--popover)",
          "color-popover-foreground": "var(--popover-foreground)",
          "color-primary": "var(--primary)",
          "color-primary-foreground": "var(--primary-foreground)",
          "color-secondary": "var(--secondary)",
          "color-secondary-foreground": "var(--secondary-foreground)",
          "color-muted": "var(--muted)",
          "color-muted-foreground": "var(--muted-foreground)",
          "color-accent": "var(--accent)",
          "color-accent-foreground": "var(--accent-foreground)",
          "color-destructive": "var(--destructive)",
          "color-destructive-foreground": "var(--destructive-foreground)",
          "color-success": "var(--success)",
          "color-warning": "var(--warning)",
          "color-border": "var(--border)",
          "color-input": "var(--input)",
          "color-ring": "var(--ring)",
          "color-chart-1": "var(--chart-1)",
          "color-chart-2": "var(--chart-2)",
          "color-chart-3": "var(--chart-3)",
          "color-chart-4": "var(--chart-4)",
          "color-chart-5": "var(--chart-5)",
          "color-sidebar": "var(--sidebar)",
          "color-sidebar-foreground": "var(--sidebar-foreground)",
          "color-sidebar-primary": "var(--sidebar-primary)",
          "color-sidebar-primary-foreground": "var(--sidebar-primary-foreground)",
          "color-sidebar-accent": "var(--sidebar-accent)",
          "color-sidebar-accent-foreground": "var(--sidebar-accent-foreground)",
          "color-sidebar-border": "var(--sidebar-border)",
          "color-sidebar-ring": "var(--sidebar-ring)",
          "font-sans": "var(--font-sans)",
          "font-mono": "var(--font-mono)",
          "font-serif": "var(--font-serif)",
          "radius-sm": "calc(var(--radius) - 4px)",
          "radius-md": "calc(var(--radius) - 2px)",
          "radius-lg": "var(--radius)",
          "radius-xl": "calc(var(--radius) + 4px)",
          "shadow-2xs": "var(--shadow-2xs)",
          "shadow-xs": "var(--shadow-xs)",
          "shadow-sm": "var(--shadow-sm)",
          "shadow": "var(--shadow)",
          "shadow-md": "var(--shadow-md)",
          "shadow-lg": "var(--shadow-lg)",
          "shadow-xl": "var(--shadow-xl)",
          "shadow-2xl": "var(--shadow-2xl)"
        }
      },
      "css": {
        "@plugin '@tailwindcss/typography'": {},
        "@custom-variant pointer-fine (@media (hover: hover) and (pointer: fine))": {},
        "@utility scrollbar-none": {
          "scrollbar-width": "none",
          "&::-webkit-scrollbar": { "display": "none" }
        },
        "@utility scrollbar-thin": {
          "scrollbar-width": "thin",
          "&::-webkit-scrollbar": { "width": "8px", "height": "8px" }
        },
        "@utility scrollbar-gutter-stable": {
          "scrollbar-gutter": "stable"
        },
        "@utility wrap-break-word": {
          "text-wrap": "wrap",
          "overflow-wrap": "anywhere",
          "word-break": "break-word"
        },
        "@utility bg-dither": {
          "background-image": "url('data:image/png;base64,')"
        },
        "@utility shimmer": {
          "background-image": "linear-gradient(to right, transparent 0%, color-mix(in oklch, currentColor 30%, transparent) 50%, transparent 100%)",
          "background-size": "200% 100%",
          "background-position": "-200% 0",
          "animation": "shimmer 1.6s ease-in-out infinite",
          "@keyframes shimmer": { "to": { "background-position": "200% 0" } }
        },
        "@utility scroll-fade-b": {
          "scroll-timeline": "--scroll-fade-b block",
          "animation": "scroll-fade-b linear both",
          "animation-timeline": "--scroll-fade-b",
          "@keyframes scroll-fade-b": {
            "from": { "mask-image": "linear-gradient(to bottom, transparent 0, black 24px, black calc(100% - 24px), transparent 100%)" },
            "to": { "mask-image": "linear-gradient(to bottom, black 0, black 100%)" }
          }
        },
        "@utility scroll-fade-x": {
          "scroll-timeline": "--scroll-fade-x inline",
          "animation": "scroll-fade-x linear both",
          "animation-timeline": "--scroll-fade-x",
          "@keyframes scroll-fade-x": {
            "from": { "mask-image": "linear-gradient(to right, transparent 0, black 24px, black calc(100% - 24px), transparent 100%)" },
            "to": { "mask-image": "linear-gradient(to right, black 0, black 100%)" }
          }
        },
        "@layer base": {
          "*": {
            "border-color": "var(--border)",
            "outline-color": "color-mix(in oklch, var(--ring) 20%, transparent)"
          },
          "body": {
            "color": "var(--foreground)",
            "font-family": "'Inter Variable', sans-serif",
            "-webkit-font-smoothing": "antialiased",
            "-moz-osx-font-smoothing": "grayscale"
          },
          ".text-brand-gradient": {
            "background": "linear-gradient(to left, var(--ai-teal), var(--ai-green))",
            "-webkit-background-clip": "text",
            "background-clip": "text",
            "color": "transparent",
            "-webkit-text-fill-color": "transparent"
          },
          "::-webkit-scrollbar": { "width": "12px" },
          "::-webkit-scrollbar-track": { "background": "var(--muted)" },
          "::-webkit-scrollbar-thumb": {
            "background": "var(--card)",
            "border-radius": "2px",
            "border": "1px solid var(--border)"
          },
          "::-webkit-scrollbar-thumb:hover": { "background": "var(--background)" },
          "@media (max-width: 640px)": {
            "::-webkit-scrollbar": { "display": "none", "width": "0 !important", "height": "0 !important", "background": "transparent !important" },
            "html": { "scrollbar-width": "none" },
            "body": { "-ms-overflow-style": "none" }
          },
          "input:-webkit-autofill, input:-webkit-autofill:hover, input:-webkit-autofill:focus, input:-webkit-autofill:active, textarea:-webkit-autofill, textarea:-webkit-autofill:hover, textarea:-webkit-autofill:focus, textarea:-webkit-autofill:active, select:-webkit-autofill, select:-webkit-autofill:hover, select:-webkit-autofill:focus, select:-webkit-autofill:active": {
            "-webkit-text-fill-color": "var(--foreground) !important",
            "-webkit-box-shadow": "0 0 0px 1000px var(--card) inset !important",
            "box-shadow": "0 0 0px 1000px var(--background) inset !important"
          },
          ".dark input:-webkit-autofill, .dark input:-webkit-autofill:hover, .dark input:-webkit-autofill:focus, .dark input:-webkit-autofill:active, .dark textarea:-webkit-autofill, .dark textarea:-webkit-autofill:hover, .dark textarea:-webkit-autofill:focus, .dark textarea:-webkit-autofill:active, .dark select:-webkit-autofill, .dark select:-webkit-autofill:hover, .dark select:-webkit-autofill:focus, .dark select:-webkit-autofill:active": {
            "-webkit-text-fill-color": "var(--foreground) !important",
            "-webkit-box-shadow": "0 0 0px 1000px var(--input) inset !important",
            "box-shadow": "0 0 0px 1000px var(--input) inset !important"
          }
        },
        "@keyframes fadeIn": {
          "from": { "opacity": "0" },
          "to": { "opacity": "1" }
        },
        "@keyframes fadeInUp": {
          "from": { "opacity": "0", "transform": "translateY(20px)" },
          "to": { "opacity": "1", "transform": "translateY(0)" }
        },
        "@keyframes fadeInWithBlur": {
          "from": { "opacity": "0", "filter": "blur(8px)" },
          "to": { "opacity": "1", "filter": "blur(0)" }
        },
        "@keyframes border-rotate": {
          "0%": { "transform": "rotate(0deg)" },
          "100%": { "transform": "rotate(360deg)" }
        },
        "@keyframes text-shimmer-move": {
          "0%": { "background-position": "100% center" },
          "100%": { "background-position": "0% center" }
        },
        "@keyframes border-shimmer-rotate": {
          "0%": { "transform": "rotate(0deg)" },
          "100%": { "transform": "rotate(360deg)" }
        },
        ".fade-in": {
          "animation": "fadeInWithBlur 0.15s ease-out forwards"
        },
        ".fade-in-up": {
          "animation": "fadeInUp 0.6s ease-out"
        },
        ".streaming-content-fade": {
          "animation": "fadeIn 0.3s ease-in"
        },
        "@media (prefers-reduced-motion: reduce)": {
          ".fade-in, .fade-in-up, .fade-in-scale": {
            "transition": "none",
            "animation": "none"
          }
        }
      }
    },
    {
      "name": "font-inter",
      "type": "registry:font",
      "title": "Inter Font",
      "description": "The Inter variable font, mapped to --font-sans.",
      "font": {
        "family": "'Inter Variable', sans-serif",
        "provider": "google",
        "import": "Inter",
        "variable": "--font-sans",
        "subsets": ["latin"],
        "dependency": "@fontsource-variable/inter"
      }
    },
    {
      "name": "font-ibm-plex-mono",
      "type": "registry:font",
      "title": "IBM Plex Mono Font",
      "description": "The IBM Plex Mono font, mapped to --font-mono.",
      "font": {
        "family": "'IBM Plex Mono', monospace",
        "provider": "google",
        "import": "IBM_Plex_Mono",
        "variable": "--font-mono",
        "subsets": ["latin"],
        "dependency": "@fontsource/ibm-plex-mono"
      }
    }
  ]
}
