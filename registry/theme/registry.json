          "shadow-color": "#0a0a0a",
          "shadow-2xs": "0px 5px 10px -6.5px hsl(0 0% 3.9216% / 0.05)",
          "shadow-xs": "0px 5px 10px -6.5px hsl(0 0% 3.9216% / 0.05)",
          "shadow-sm": "0px 5px 10px -6.5px hsl(0 0% 3.9216% / 0.1), 0px 1px 2px -7.5px hsl(0 0% 3.9216% / 0.1)",
          "shadow": "0px 5px 10px -6.5px hsl(0 0% 3.9216% / 0.1), 0px 1px 2px -7.5px hsl(0 0% 3.9216% / 0.1)",
          "shadow-md": "0px 5px 10px -6.5px hsl(0 0% 3.9216% / 0.1), 0px 2px 4px -7.5px hsl(0 0% 3.9216% / 0.1)",
          "shadow-lg": "0px 5px 10px -6.5px hsl(0 0% 3.9216% / 0.1), 0px 4px 6px -7.5px hsl(0 0% 3.9216% / 0.1)",
          "shadow-xl": "0px 5px 10px -6.5px hsl(0 0% 3.9216% / 0.1), 0px 8px 10px -7.5px hsl(0 0% 3.9216% / 0.1)",
          "shadow-2xl": "0px 5px 10px -6.5px hsl(0 0% 3.9216% / 0.25)",
          "tracking-normal": "0em",
          "spacing": "0.22rem",
          "ai-green": "#4eaf84",
          "ai-teal": "#28a7b8",
          "ease-out": "cubic-bezier(0.23, 1, 0.32, 1)",
          "ease-in-out": "cubic-bezier(0.77, 0, 0.175, 1)",
          "ease-drawer": "cubic-bezier(0.32, 0.72, 0, 1)"
